# ===========================================
# ETF Autopilot - Environment Variables Template
# ===========================================
# Copy this file to `.env` and fill in real values.
# NEVER commit your real `.env` file.

# ---- Database (Prisma, SQLite) ----
# Local SQLite file path. Default works for most setups.
DATABASE_URL="file:/app/db/custom.db"

# ---- Tushare (backup data source, optional) ----
# The system uses Akshare as the primary data source.
# Tushare is only used as a backup/verification source.
# Get a token at https://tushare.pro if you want to enable it.
TUSHARE_TOKEN=""
